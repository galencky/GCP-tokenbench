# ── Required ──
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/tokenbench?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-random-64-char-string
ENCRYPTION_KEY=          # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Optional ──
GOOGLE_CLIENT_ID=        # Google OAuth 2.0 Client ID (enables Google Sign-In)
ALLOWED_ORIGINS=http://localhost:5000   # Comma-separated allowed CORS origins
DEV_LOGIN=false          # Set to "true" to enable login without Google (local dev only)
